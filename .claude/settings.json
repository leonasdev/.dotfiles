{
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "git-commands@dot-claude": true
  },
  "extraKnownMarketplaces": {
    "dot-claude": {
      "source": {
        "source": "github",
        "repo": "leonasdev/dot-claude"
      }
    }
  },
  "statusLine": {
    "type": "command",
    "command": "command -v ccstatusline > /dev/null 2>&1 && ccstatusline || printf '\\033[33m[WARNING] ccstatusline is not installed. Run: npm install -g ccstatusline@latest\\033[0m'",
    "padding": 0
  }
}